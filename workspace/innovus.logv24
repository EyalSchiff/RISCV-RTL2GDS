[01/26 17:27:05      0s] @innovus 142> 

###########################################################
# Add Block Rings and Halos to all 4 DMEM/DCCM instances
###########################################################

#     
set dmem_list [list $d0 $d1 $d2 $d3]

foreach dmem $dmem_list {
    # 1.      
    deselect_obj -all
    select_obj $dmem
    
    # 2.      (Block Rings)
    #  :  -M1/M2  ,       -M1
    add_rings -around selected -type block_rings -nets "$design(digital_gnd) $design(digital_vdd)" \
        -layer {bottom M1 top M1 right M2 left M2} \
        -width 3 -spacing 0.5
    
    # 3.  Placement Halo (    )
    # halo  10um       "" 
    create_place_halo -halo_deltas {10 10 10 10} -insts $dmem -snap_to_site
}
