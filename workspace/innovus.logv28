[01/27 10:55:42    121s] @innovus 171> # Add M2 routing blockages around vertical power stripes to prevent M2 routing DRC [1Gs near them:
# Add M2 routing blockages around vertical power stripes to prevent M2 routing DRCs near them:
enics_message "Creating M2 blockage around stripes"
deselect_obj -all
deselect_routes
[01/27 10:55:42    121s] @innovus 172> enics_message "Creating M2 blockage around stripes"
[01/27 10:55:42    121s] ENICSINFO: Creating M2 blockage around stripes
[01/27 10:55:42    121s] @innovus 173> deselect_obj -all
[01/27 10:55:42    121s] @innovus 174> deselect_routes
[01/27 10:55:42    121s] @innovus 175> select_routes -shapes stripe -layer M2 -nets $design(M2_stripe_nets)
select_routes -shapes stripe -layer M2 -nets $design(M2_stripe_nets)
foreach stripe [get_db selected] {
    create_route_blockage -name M2_pwr_stripe_route_blk \
        -layers "M1 M2" \
        -spacing 0.2 \
