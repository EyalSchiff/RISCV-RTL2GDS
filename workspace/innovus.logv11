[01/25 16:14:08      0s] + #edit_pin -fix_overlap 1 -spread_direction clockwise -side Bottom -layer 4 -spread_type side  [1G
[01/25 16:14:08      0s] + edit_pin -spread_type start -start {0 0} -spread_direction clockwise -layer {3 4}  \
