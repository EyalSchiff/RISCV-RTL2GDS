[01/25 16:14:08      0s] + -nets "$design(digital_gnd) $design(digital_vdd) $design(io_gnd) $design(io_vdd)"
[01/25 16:14:08      0s] + } elseif {$design(FULLCHIP_OR_MACRO)=="MACRO"} {
