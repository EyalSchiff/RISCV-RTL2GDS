    }
    leakage_power() {
      related_pg_pin : "VDDCE";
      when :"!RET1N";
      value : 9.140e-03;
    }
    /* Standby Leakage Power */
    leakage_power() {
      related_pg_pin : "VDDPE";
      value : 9.359e-03;
    }
    leakage_power() {
      related_pg_pin : "VDDCE";
      value : 9.114e-03;
    }
  }
}
